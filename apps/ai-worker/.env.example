REDIS_HOST=localhost
REDIS_PORT=6379
MONGODB_URI=mongodb://localhost:27017/lead-agent

OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: Override base URL and API keys for local and cloud models separately
# OLLAMA_LOCAL_BASE_URL=http://127.0.0.1:11434
# OLLAMA_CLOUD_BASE_URL=https://api.openai.com
# OLLAMA_LOCAL_API_KEY=ollama
# OLLAMA_CLOUD_API_KEY=sk-...

OLLAMA_LOCAL_MODEL=gemma4:26b
OLLAMA_CLOUD_MODEL=gemma4:31b-cloud
# OLLAMA_MODEL is kept for backwards compatibility
OLLAMA_MODEL=gemma4:31b-cloud

OLLAMA_TIMEOUT_SECONDS=800
OLLAMA_LOCAL_TIMEOUT_SECONDS=90
OLLAMA_MAX_TOKENS=15000
OLLAMA_LOCAL_TO_CLOUD_FALLBACK_TASKS=website_selection

WEBSITE_SELECTION_MIN_CONFIDENCE=0.45
WEBSITE_SELECTION_CLOUD_VERIFY=true

CRAWLER_MAX_PAGES=10
CRAWLER_TIMEOUT_SECONDS=15
CRAWLER_MAX_REDIRECTS=5
CRAWLER_MAX_RESPONSE_BYTES=2000000
CRAWLER_VERIFY_TLS=true
CRAWLER_USER_AGENT=AegisSafeForgeLeadResearchBot/0.1 (+https://aegissafeforge.com)

EXTRACTION_MAX_EVIDENCE_ITEMS=12
EXTRACTION_MAX_CHARS_PER_EVIDENCE=4000
EXTRACTION_MIN_TEXT_LENGTH=80
EXTRACTION_MIN_CONFIDENCE=0.2
ENRICHMENT_MAX_SEARCH_QUERIES=6
CONTACT_FALLBACK_MAX_PAGES=6
CONTACT_DISCOVERY_MAX_CONTACTS=10

LLM_LOG_ENABLED=false
LLM_LOG_REDACT=true
LLM_LOG_MAX_CHARS=20000
LLM_LOG_DIR=logs/llm
AI_WORKER_LOG_DIR=logs
AVA_PUBLIC_RELEASE_MODE=local-dev

# AVA has no authentication in this MVP. Do not expose it directly to the public internet.

# Optional official LinkedIn API enrichment.
# Requires r_organization_social and company linkedin_organization_id values.
# LINKEDIN_ACCESS_TOKEN=
LINKEDIN_VERSION=202604
LINKEDIN_POSTS_LIMIT=5

# Optional public LinkedIn fallback. Disabled by default.
# Only fetches publicly reachable company profile text; it does not bypass login walls.
LINKEDIN_PUBLIC_SCRAPER_ENABLED=false
LINKEDIN_PUBLIC_SCRAPER_TIMEOUT_SECONDS=15
LINKEDIN_PUBLIC_SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0 Safari/537.36

# Optional search providers for enrichment plugins.
# BRAVE_SEARCH_API_KEY=
# BING_SEARCH_API_KEY=
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=
